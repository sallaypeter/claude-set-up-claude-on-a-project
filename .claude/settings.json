{
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(node --test:*)"
    ],
    "ask": [
      "Bash(git push:*)"
